# Notification channel priority: Telegram (if configured) → Email (if configured) → console only

# Optional — email notifications (fallback when Telegram is not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
MAIL_SUBJECT_PREFIX=

LATITUDE=
LONGITUDE=

TUYA_DEVICE_ID=
TUYA_DEVICE_NAME=

# Get these from https://iot.tuya.com → your Cloud Project
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
# Europe/Africa: tuyaeu.com | Americas: tuyaus.com | China: tuyacn.com
TUYA_BASE_URL=https://openapi.tuyaeu.com
# Optional — auto-discovered if left empty
TUYA_SWITCH_CODE=

# Optional — Telegram (interactive override + default notification channel when configured)
# Create a bot via @BotFather and get your chat ID (see README)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Minutes to wait for a Telegram response before auto-executing (default: 10)
TELEGRAM_TIMEOUT_MIN=10
# Optional — wife's chat ID: replaces 🤖 Auto button with 👩🏾 Ask Wife
TELEGRAM_WIFE_CHAT_ID=
